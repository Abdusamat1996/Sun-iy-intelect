        "import numpy as np\n",
        "# Neuron Parameters\n",
        "class LIFNeuron:\n",
        "    def __init__(self, threshold, reset_value, decay_factor, refractory_period):\n",
        "        self.threshold = threshold\n",
        "        self.reset_value = reset_value\n",
        "        self.decay_factor = decay_factor\n",
        "        self.refractory_period = refractory_period\n",
        "        self.membrane_potential = 0.0 # Initialize membrane potential\n",
        "        self.spike_time = -1\n",
        "        self.refractory_end_time = -1\n",
        "\n",
        "    def update(self, incoming_spikes, current_time):\n",
        "        if current_time < self.refractory_end_time:\n",
        "            return False\n",
        "\n",
        "        self.membrane_potential *= self.decay_factor\n",
        "        # incoming_spikes could be a scalar or an array, so np.sum handles both cases\n",
        "        if isinstance(incoming_spikes, np.ndarray):\n",
        "            self.membrane_potential += np.sum(incoming_spikes)\n",
        "        else:\n",
        "            self.membrane_potential += incoming_spikes\n",
        "\n",
        "        if self.membrane_potential >= self.threshold:\n",
        "            self.spike_time = current_time\n",
        "            self.membrane_potential = self.reset_value\n",
        "            self.refractory_end_time = current_time + self.refractory_period\n",
        "            return True\n",
        "        return False\n",
        "\n",
        "# Synapse Parameters\n",
        "class Synapse:\n",
        "    def __init__(self, weight):\n",
        "        self.weight = weight\n",
        "\n",
        "# Spike-Timing-Dependent Plasticity (STDP)\n",
        "def stdp(pre_spike_time, post_spike_time, weight, learning_rate,\n",
        "         tau_positive, tau_negative):\n",
        "    # Only apply STDP if both pre- and post-synaptic neurons spiked\n",
        "    if pre_spike_time >= 0 and post_spike_time >= 0:\n",
        "        delta_t = post_spike_time - pre_spike_time\n",
        "        if delta_t > 0: # Pre-synaptic spike before post-synaptic spike (potentiation)\n",
        "            return weight + learning_rate * np.exp(-delta_t / tau_positive)\n",
        "        else: # Post-synaptic spike before pre-synaptic spike (depression) or simultaneous\n",
        "            return weight - learning_rate * np.exp(delta_t / tau_negative)\n",
        "    return weight # No STDP if one or both neurons did not spike\n",
        "\n",
        "# Simulation Parameters\n",
        "time_steps = 100\n",
        "input_size = 5\n",
        "hidden_size = 3\n",
        "output_size = 1\n",
        "\n",
        "# Network Initialization\n",
        "input_neurons = [LIFNeuron(threshold=1.0, reset_value=0.0,\n",
        "                           decay_factor=0.9, refractory_period=2) for _ in range(input_size)]\n",
        "hidden_neurons = [LIFNeuron(threshold=1.0, reset_value=0.0,\n",
        "                            decay_factor=0.9, refractory_period=2) for _ in range(hidden_size)]\n",
        "output_neurons = [LIFNeuron(threshold=1.0, reset_value=0.0,\n",
        "                            decay_factor=0.9, refractory_period=2) for _ in range(output_size)]\n",
        "\n",
        "input_to_hidden_synapses = np.random.rand(input_size, hidden_size)\n",
        "hidden_to_output_synapses = np.random.rand(hidden_size, output_size)\n",
        "\n",
        "learning_rate = 0.01\n",
        "tau_positive = 20\n",
        "tau_negative = 20\n",
        "\n",
        "# Spike Train Pattern to Detect\n",
        "pattern = [1, 0, 1, 0, 1]\n",
        "\n",
        "# Simulation Loop\n",
        "for t in range(time_steps):\n",
        "    # Generate input spike trains (random for this example)\n",
        "    # Input spikes are binary (0 or 1)\n",
        "    input_spikes = np.random.randint(0, 2, size=input_size)\n",
        "\n",
        "    # Propagate spikes from input to hidden layer\n",
        "    hidden_incoming_currents = np.zeros(hidden_size)\n",
        "    for i, input_neuron in enumerate(input_neurons):\n",
        "        if input_spikes[i] == 1: # If input neuron 'i' spikes\n",
        "            # Update input neuron (even if it's just a proxy for incoming spikes)\n",
        "            # In this setup, input_neurons are just a placeholder for spike_time tracking\n",
        "            input_neuron.spike_time = t\n",
        "            # Distribute weighted spikes to hidden neurons\n",
        "            hidden_incoming_currents += input_to_hidden_synapses[i, :]\n",
        "\n",
        "    # Update hidden neurons\n",
        "    hidden_actual_spikes = np.zeros(hidden_size)\n",
        "    output_incoming_currents = np.zeros(output_size)\n",
        "    for j, hidden_neuron in enumerate(hidden_neurons):\n",
        "        if hidden_neuron.update(hidden_incoming_currents[j], t):\n",
        "            hidden_actual_spikes[j] = 1 # Mark hidden neuron as spiked\n",
        "            # Distribute weighted spikes to output neurons\n",
        "            output_incoming_currents += hidden_to_output_synapses[j, :]\n",
        "\n",
        "    # Update output neurons\n",
        "    output_actual_spikes = np.zeros(output_size)\n",
        "    for k, output_neuron in enumerate(output_neurons):\n",
        "        if output_neuron.update(output_incoming_currents[k], t):\n",
        "            output_actual_spikes[k] = 1 # Mark output neuron as spiked\n",
        "\n",
        "    # STDP Learning\n",
        "    # Input to Hidden layer STDP\n",
        "    for i in range(input_size):\n",
        "        for j in range(hidden_size):\n",
        "            input_to_hidden_synapses[i, j] = stdp(input_neurons[i].spike_time,\n",
        "                                                  hidden_neurons[j].spike_time,\n",
        "                                                  input_to_hidden_synapses[i, j],\n",
        "                                                  learning_rate, tau_positive, tau_negative)\n",
        "\n",
        "    # Hidden to Output layer STDP\n",
        "    for j in range(hidden_size):\n",
        "        for k in range(output_size):\n",
        "            hidden_to_output_synapses[j, k] = stdp(hidden_neurons[j].spike_time,\n",
        "                                                  output_neurons[k].spike_time,\n",
        "                                                  hidden_to_output_synapses[j, k],\n",
        "                                                  learning_rate, tau_positive, tau_negative)\n",
        "\n",
        "    # Check if pattern is detected (This part needs clarification on what 'pattern detection' means)\n",
        "    # Assuming 'pattern' refers to specific input neurons spiking at this timestep\n",
        "    detected = True\n",
        "    for i in range(input_size):\n",
        "        if pattern[i] == 1 and input_spikes[i] != 1: # If pattern expects a spike but it's not there\n",
        "            detected = False\n",
        "            break\n",
        "        elif pattern[i] == 0 and input_spikes[i] == 1: # If pattern expects no spike but it's there\n",
        "            # This condition might need adjustment based on pattern definition\n",
        "            # For now, let's assume we only care about '1's matching\n",
        "            pass\n",
        "\n",
        "    if detected and any(input_spikes == pattern): # Added a condition to ensure the pattern is present in current input spikes\n",
        "        print(f\"Pattern detected at time step {t}\")\n"
